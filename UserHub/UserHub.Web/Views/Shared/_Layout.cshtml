@using UserHub.Application.DTOs
@using UserHub.Shared.Constants
@using UserHub.Shared.Extensions
@{
    var sessionUser = Context.Session.GetObject<SessionUserDto>(SessionKeys.SessionUser);
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
}
<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — UserHub</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

@if (sessionUser != null)
{
    <div class="d-flex" id="wrapper">
        <!-- Sidebar -->
        <nav id="sidebar" class="bg-dark border-end border-secondary d-flex flex-column p-0">
            <div class="sidebar-brand d-flex align-items-center px-3 py-3 border-bottom border-secondary">
                <i class="bi bi-hexagon-fill text-primary me-2 fs-5"></i>
                <span class="fw-bold text-white fs-6 brand-text">UserHub</span>
            </div>
            <ul class="nav flex-column flex-grow-1 pt-2">
                <li class="nav-item">
                    <a class="nav-link @(currentController == "Home" ? "active" : "")" asp-controller="Home" asp-action="Dashboard">
                        <i class="bi bi-speedometer2 me-2"></i><span class="nav-label">Dashboard</span>
                    </a>
                </li>
                @if (sessionUser.IsSuperAdmin || (sessionUser.Permissions.TryGetValue("Users", out var up) && up.CanList))
                {
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Users" ? "active" : "")" asp-controller="Users" asp-action="Index">
                            <i class="bi bi-people-fill me-2"></i><span class="nav-label">Users</span>
                        </a>
                    </li>
                }
                @if (sessionUser.IsSuperAdmin || (sessionUser.Permissions.TryGetValue("Roles", out var rp) && rp.CanList))
                {
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Roles" ? "active" : "")" asp-controller="Roles" asp-action="Index">
                            <i class="bi bi-shield-lock-fill me-2"></i><span class="nav-label">Roles</span>
                        </a>
                    </li>
                }
                @if (sessionUser.IsSuperAdmin || (sessionUser.Permissions.TryGetValue("Modules", out var mp) && mp.CanList))
                {
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Modules" ? "active" : "")" asp-controller="Modules" asp-action="Index">
                            <i class="bi bi-grid-3x3-gap me-2"></i><span class="nav-label">Modules</span>
                        </a>
                    </li>
                }
            </ul>
            <div class="sidebar-footer p-3 border-top border-secondary">
                <div class="d-flex align-items-center">
                    <div class="avatar-circle me-2">@sessionUser.FullName[0]</div>
                    <div class="flex-grow-1 overflow-hidden nav-label">
                        <div class="text-white small fw-semibold text-truncate">@sessionUser.FullName</div>
                        <div class="text-muted" style="font-size:0.7rem;">@string.Join(", ", sessionUser.Roles)</div>
                    </div>
                </div>
            </div>
        </nav>

        <!-- Page content -->
        <div id="page-content" class="flex-grow-1 d-flex flex-column min-vh-100">
            <!-- Topbar -->
            <nav class="navbar navbar-dark bg-dark border-bottom border-secondary px-3 py-2">
                <button class="btn btn-sm btn-outline-secondary" id="sidebarToggle">
                    <i class="bi bi-list"></i>
                </button>
                <span class="navbar-text text-muted small ms-3">@ViewData["Title"]</span>
                <div class="ms-auto d-flex align-items-center gap-2">
                    <span class="text-muted small d-none d-md-inline">@sessionUser.Username</span>
                    <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger">
                            <i class="bi bi-box-arrow-right"></i>
                        </button>
                    </form>
                </div>
            </nav>

            <!-- Main content -->
            <main class="flex-grow-1 p-4">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @RenderBody()
            </main>
        </div>
    </div>
}
else
{
    @RenderBody()
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="~/js/site.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
