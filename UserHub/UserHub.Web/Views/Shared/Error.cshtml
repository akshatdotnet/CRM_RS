@{ Layout = "_Layout"; ViewData["Title"] = "Error"; }
<div class="text-center py-5">
    <i class="bi bi-exclamation-triangle text-warning" style="font-size:4rem;"></i>
    <h4 class="mt-3 text-white">An error occurred</h4>
    <p class="text-muted">Something went wrong. Please try again.</p>
    <a asp-controller="Home" asp-action="Dashboard" class="btn btn-outline-primary">
        <i class="bi bi-house me-2"></i>Back to Dashboard
    </a>
</div>
