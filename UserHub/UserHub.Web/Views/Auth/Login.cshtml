@model UserHub.Application.DTOs.LoginDto
@{ Layout = null; ViewData["Title"] = "Login"; }
<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>UserHub — Login</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"/>
    <link rel="stylesheet" href="~/css/site.css"/>
</head>
<body class="login-page">
<div class="login-wrapper d-flex align-items-center justify-content-center min-vh-100">
    <div class="login-card card bg-dark border border-secondary shadow-lg" style="width:420px;">
        <div class="card-body p-4">
            <div class="text-center mb-4">
                <i class="bi bi-hexagon-fill text-primary" style="font-size:2.5rem;"></i>
                <h4 class="mt-2 fw-bold text-white">UserHub</h4>
                <p class="text-muted small">Sign in to your account</p>
            </div>

            <form asp-action="Login" asp-controller="Auth" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ReturnUrl"/>

                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                <div class="mb-3">
                    <label asp-for="Username" class="form-label text-muted small">Username</label>
                    <div class="input-group">
                        <span class="input-group-text bg-dark border-secondary">
                            <i class="bi bi-person text-secondary"></i>
                        </span>
                        <input asp-for="Username" class="form-control bg-dark border-secondary text-white"
                               placeholder="Enter username" autocomplete="username"/>
                    </div>
                    <span asp-validation-for="Username" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label text-muted small">Password</label>
                    <div class="input-group">
                        <span class="input-group-text bg-dark border-secondary">
                            <i class="bi bi-lock text-secondary"></i>
                        </span>
                        <input asp-for="Password" type="password" class="form-control bg-dark border-secondary text-white"
                               placeholder="Enter password" autocomplete="current-password"/>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100 fw-semibold">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                </button>
            </form>

            <hr class="border-secondary my-3"/>
            <div class="text-center">
                <p class="text-muted small mb-1">Default credentials:</p>
                <code class="text-info small">superadmin / Admin@1234</code>
            </div>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
