@model UserHub.Application.DTOs.EditRoleDto
@{ ViewData["Title"] = "Edit Role"; }
<div class="d-flex align-items-center mb-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
    <h5 class="mb-0 fw-semibold text-white">Edit Role</h5>
</div>
<div class="card bg-dark border border-secondary" style="max-width:500px;">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden"/>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
            <div class="mb-3">
                <label asp-for="Name" class="form-label text-muted small">Role Name</label>
                <input asp-for="Name" class="form-control bg-dark border-secondary text-white"/>
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="mb-4">
                <label asp-for="Description" class="form-label text-muted small">Description</label>
                <textarea asp-for="Description" class="form-control bg-dark border-secondary text-white" rows="2"></textarea>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Save</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
