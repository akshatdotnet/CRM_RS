@model IEnumerable<UserHub.Application.DTOs.PermissionSetDto>
@{ ViewData["Title"] = "Role Permissions"; var role = ViewBag.Role as UserHub.Application.DTOs.RoleDto; }

<div class="d-flex align-items-center mb-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
    <h5 class="mb-0 fw-semibold text-white">Permissions — @role?.Name</h5>
</div>

<div class="card bg-dark border border-secondary" style="max-width:800px;">
    <div class="card-body p-4">
        <form asp-action="Permissions" asp-route-id="@role?.Id" method="post">
            @Html.AntiForgeryToken()

            <div class="table-responsive">
                <table class="table table-dark small mb-4">
                    <thead>
                        <tr>
                            <th class="border-secondary text-muted fw-normal">Module</th>
                            <th class="border-secondary text-muted fw-normal text-center">View</th>
                            <th class="border-secondary text-muted fw-normal text-center">List</th>
                            <th class="border-secondary text-muted fw-normal text-center">Create</th>
                            <th class="border-secondary text-muted fw-normal text-center">Edit</th>
                            <th class="border-secondary text-muted fw-normal text-center">Delete</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{int i = 0;}
                        @foreach (var perm in Model)
                        {
                            <tr>
                                <td class="border-secondary text-white">
                                    @perm.ModuleDisplayName
                                    <input type="hidden" name="permissions[@i].ModuleId" value="@perm.ModuleId"/>
                                    <input type="hidden" name="permissions[@i].ModuleName" value="@perm.ModuleName"/>
                                    <input type="hidden" name="permissions[@i].ModuleDisplayName" value="@perm.ModuleDisplayName"/>
                                </td>
                                <td class="border-secondary text-center">
                                    <input type="checkbox" name="permissions[@i].CanView" class="form-check-input" @(perm.CanView ? "checked" : "")/>
                                </td>
                                <td class="border-secondary text-center">
                                    <input type="checkbox" name="permissions[@i].CanList" class="form-check-input" @(perm.CanList ? "checked" : "")/>
                                </td>
                                <td class="border-secondary text-center">
                                    <input type="checkbox" name="permissions[@i].CanCreate" class="form-check-input" @(perm.CanCreate ? "checked" : "")/>
                                </td>
                                <td class="border-secondary text-center">
                                    <input type="checkbox" name="permissions[@i].CanEdit" class="form-check-input" @(perm.CanEdit ? "checked" : "")/>
                                </td>
                                <td class="border-secondary text-center">
                                    <input type="checkbox" name="permissions[@i].CanDelete" class="form-check-input" @(perm.CanDelete ? "checked" : "")/>
                                </td>
                            </tr>
                            i++;
                        }
                    </tbody>
                </table>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Save Permissions
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
