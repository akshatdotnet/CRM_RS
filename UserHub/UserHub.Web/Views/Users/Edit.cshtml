@model UserHub.Application.DTOs.EditUserDto
@{ ViewData["Title"] = "Edit User"; }

<div class="d-flex align-items-center mb-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
    <h5 class="mb-0 fw-semibold text-white">Edit User</h5>
</div>

<div class="card bg-dark border border-secondary" style="max-width:700px;">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden"/>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label asp-for="FirstName" class="form-label text-muted small">First Name</label>
                    <input asp-for="FirstName" class="form-control bg-dark border-secondary text-white"/>
                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="LastName" class="form-label text-muted small">Last Name</label>
                    <input asp-for="LastName" class="form-control bg-dark border-secondary text-white"/>
                    <span asp-validation-for="LastName" class="text-danger small"></span>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Email" class="form-label text-muted small">Email</label>
                <input asp-for="Email" class="form-control bg-dark border-secondary text-white"/>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label class="form-label text-muted small">Roles</label>
                <div class="row g-2">
                    @foreach (var role in (IEnumerable<UserHub.Application.DTOs.RoleDto>)ViewBag.Roles)
                    {
                        <div class="col-6 col-md-4">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="RoleIds" value="@role.Id"
                                       id="role_@role.Id"
                                       @(Model.RoleIds.Contains(role.Id) ? "checked" : "")/>
                                <label class="form-check-label text-muted small" for="role_@role.Id">@role.Name</label>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="form-check mb-4">
                <input asp-for="IsActive" class="form-check-input" type="checkbox"/>
                <label asp-for="IsActive" class="form-check-label text-muted small">Active</label>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Save Changes
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                <a asp-action="ChangePassword" asp-route-id="@Model.Id" class="btn btn-outline-warning ms-auto">
                    <i class="bi bi-key me-1"></i>Change Password
                </a>
            </div>
        </form>
    </div>
</div>
