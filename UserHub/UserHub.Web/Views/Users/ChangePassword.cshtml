@model UserHub.Application.DTOs.ChangePasswordDto
@{ ViewData["Title"] = "Change Password"; }

<div class="d-flex align-items-center mb-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
    <h5 class="mb-0 fw-semibold text-white">Change Password</h5>
</div>

<div class="card bg-dark border border-secondary" style="max-width:420px;">
    <div class="card-body p-4">
        <form asp-action="ChangePassword" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="UserId" type="hidden"/>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label text-muted small">New Password</label>
                <input asp-for="NewPassword" type="password" class="form-control bg-dark border-secondary text-white"/>
                <span asp-validation-for="NewPassword" class="text-danger small"></span>
            </div>
            <div class="mb-4">
                <label asp-for="ConfirmPassword" class="form-label text-muted small">Confirm Password</label>
                <input asp-for="ConfirmPassword" type="password" class="form-control bg-dark border-secondary text-white"/>
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning">
                    <i class="bi bi-key me-1"></i>Change Password
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
