@model UserHub.Application.DTOs.UserDetailDto
@{ ViewData["Title"] = "User Details"; }

<div class="d-flex align-items-center mb-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
    <h5 class="mb-0 fw-semibold text-white">User Details</h5>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary ms-auto">
        <i class="bi bi-pencil me-1"></i>Edit
    </a>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card bg-dark border border-secondary h-100">
            <div class="card-body p-4 text-center">
                <div class="avatar-circle-lg mx-auto mb-3">@Model.FullName[0]</div>
                <h6 class="fw-bold text-white">@Model.FullName</h6>
                <div class="text-muted small">@@@Model.Username</div>
                <div class="text-muted small mb-3">@Model.Email</div>
                @if (Model.IsActive)
                {
                    <span class="badge bg-success bg-opacity-25 text-success">Active</span>
                }
                else
                {
                    <span class="badge bg-danger bg-opacity-25 text-danger">Inactive</span>
                }
                <hr class="border-secondary"/>
                <div class="text-start">
                    <div class="d-flex justify-content-between small mb-1">
                        <span class="text-muted">Created</span>
                        <span class="text-white">@Model.CreatedAt.ToString("dd MMM yyyy")</span>
                    </div>
                    <div class="d-flex justify-content-between small mb-1">
                        <span class="text-muted">Last Login</span>
                        <span class="text-white">@(Model.LastLoginAt?.ToString("dd MMM yyyy HH:mm") ?? "Never")</span>
                    </div>
                </div>
                <hr class="border-secondary"/>
                <div class="text-start">
                    <div class="text-muted small mb-2">Assigned Roles</div>
                    @foreach (var r in Model.Roles)
                    {
                        <span class="badge bg-primary bg-opacity-25 text-primary me-1 mb-1">@r.Name</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card bg-dark border border-secondary">
            <div class="card-header border-secondary">
                <span class="fw-semibold text-white small">Permission Matrix</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-dark mb-0 small">
                        <thead>
                            <tr>
                                <th class="border-secondary text-muted fw-normal ps-3">Module</th>
                                <th class="border-secondary text-muted fw-normal text-center">View</th>
                                <th class="border-secondary text-muted fw-normal text-center">List</th>
                                <th class="border-secondary text-muted fw-normal text-center">Create</th>
                                <th class="border-secondary text-muted fw-normal text-center">Edit</th>
                                <th class="border-secondary text-muted fw-normal text-center">Delete</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var kv in Model.Permissions)
                            {
                                var p = kv.Value;
                                <tr>
                                    <td class="border-secondary ps-3 text-white">@p.ModuleDisplayName</td>
                                    <td class="border-secondary text-center">@(p.CanView ? "✓" : "—")</td>
                                    <td class="border-secondary text-center">@(p.CanList ? "✓" : "—")</td>
                                    <td class="border-secondary text-center">@(p.CanCreate ? "✓" : "—")</td>
                                    <td class="border-secondary text-center">@(p.CanEdit ? "✓" : "—")</td>
                                    <td class="border-secondary text-center">@(p.CanDelete ? "✓" : "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
