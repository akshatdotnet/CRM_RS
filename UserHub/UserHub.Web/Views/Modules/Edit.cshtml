@model UserHub.Application.DTOs.ModuleDto
@{ ViewData["Title"] = "Edit Module"; }
<div class="d-flex align-items-center mb-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
    <h5 class="mb-0 fw-semibold text-white">Edit Module</h5>
</div>
<div class="card bg-dark border border-secondary" style="max-width:500px;">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden"/>
            <input asp-for="Name" type="hidden"/>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
            <div class="mb-3">
                <label asp-for="DisplayName" class="form-label text-muted small">Display Name</label>
                <input asp-for="DisplayName" class="form-control bg-dark border-secondary text-white"/>
            </div>
            <div class="mb-3">
                <label asp-for="Icon" class="form-label text-muted small">Bootstrap Icon class</label>
                <input asp-for="Icon" class="form-control bg-dark border-secondary text-white"/>
            </div>
            <div class="mb-4">
                <label asp-for="SortOrder" class="form-label text-muted small">Sort Order</label>
                <input asp-for="SortOrder" type="number" class="form-control bg-dark border-secondary text-white"/>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Save</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
