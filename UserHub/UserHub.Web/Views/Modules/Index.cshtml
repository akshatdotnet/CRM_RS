@model IEnumerable<UserHub.Application.DTOs.ModuleDto>
@{ ViewData["Title"] = "Modules"; }
<div class="d-flex align-items-center justify-content-between mb-3">
    <h5 class="mb-0 fw-semibold text-white"><i class="bi bi-grid-3x3-gap text-info me-2"></i>Modules</h5>
    <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>New Module</a>
</div>
<div class="card bg-dark border border-secondary">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0">
                <thead>
                    <tr>
                        <th class="border-secondary text-muted fw-normal small ps-3">Name</th>
                        <th class="border-secondary text-muted fw-normal small">Controller</th>
                        <th class="border-secondary text-muted fw-normal small">Icon</th>
                        <th class="border-secondary text-muted fw-normal small">Order</th>
                        <th class="border-secondary text-muted fw-normal small">Status</th>
                        <th class="border-secondary text-muted fw-normal small text-end pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in Model)
                    {
                        <tr>
                            <td class="border-secondary ps-3 text-white fw-semibold">
                                <i class="@m.Icon me-2 text-muted"></i>@m.DisplayName
                            </td>
                            <td class="border-secondary text-muted small">@m.ControllerName</td>
                            <td class="border-secondary text-muted small"><code>@m.Icon</code></td>
                            <td class="border-secondary text-muted">@m.SortOrder</td>
                            <td class="border-secondary">
                                @if (m.IsActive) { <span class="badge bg-success bg-opacity-25 text-success">Active</span> }
                                else { <span class="badge bg-secondary bg-opacity-25 text-secondary">Inactive</span> }
                            </td>
                            <td class="border-secondary text-end pe-3">
                                <a asp-action="Edit" asp-route-id="@m.Id" class="btn btn-sm btn-outline-primary me-1"><i class="bi bi-pencil"></i></a>
                                <form asp-action="Delete" asp-route-id="@m.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Delete this module?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
