@model UserHub.Application.DTOs.DashboardStatsDto
@{ ViewData["Title"] = "Dashboard"; }

<div class="row g-4 mb-4">
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card bg-dark border border-secondary h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-primary bg-opacity-10 text-primary rounded p-3">
                    <i class="bi bi-people-fill fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Total Users</div>
                    <div class="fs-3 fw-bold text-white">@Model.TotalUsers</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card bg-dark border border-secondary h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-success bg-opacity-10 text-success rounded p-3">
                    <i class="bi bi-person-check-fill fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Active Users</div>
                    <div class="fs-3 fw-bold text-white">@Model.ActiveUsers</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card bg-dark border border-secondary h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-warning bg-opacity-10 text-warning rounded p-3">
                    <i class="bi bi-shield-lock-fill fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Roles</div>
                    <div class="fs-3 fw-bold text-white">@Model.TotalRoles</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card bg-dark border border-secondary h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-info bg-opacity-10 text-info rounded p-3">
                    <i class="bi bi-grid-3x3-gap fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Modules</div>
                    <div class="fs-3 fw-bold text-white">@Model.TotalModules</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card bg-dark border border-secondary">
    <div class="card-header border-secondary d-flex align-items-center">
        <i class="bi bi-activity text-primary me-2"></i>
        <span class="fw-semibold text-white">Recent Activity</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0">
                <thead>
                    <tr>
                        <th class="border-secondary text-muted fw-normal small">User</th>
                        <th class="border-secondary text-muted fw-normal small">Action</th>
                        <th class="border-secondary text-muted fw-normal small">Module</th>
                        <th class="border-secondary text-muted fw-normal small">Time</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in Model.RecentActivity)
                    {
                        <tr>
                            <td class="border-secondary"><span class="text-white">@a.Username</span></td>
                            <td class="border-secondary"><span class="badge bg-primary bg-opacity-25 text-primary">@a.Action</span></td>
                            <td class="border-secondary text-muted">@a.Module</td>
                            <td class="border-secondary text-muted small">@a.OccurredAt.ToString("dd MMM HH:mm")</td>
                        </tr>
                    }
                    @if (!Model.RecentActivity.Any())
                    {
                        <tr><td colspan="4" class="text-center text-muted py-4 border-secondary">No activity yet.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
