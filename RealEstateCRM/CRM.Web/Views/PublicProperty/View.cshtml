@model PublicPropertyViewModel
@{
    Layout = null; // standalone page, no admin sidebar
    var primaryPhoto = Model.Photos.FirstOrDefault(p => p.IsPrimary)?.FilePath ?? Model.Photos.FirstOrDefault()?.FilePath;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.Title — @Model.City</title>
    <meta name="description" content="@Model.Description[..Math.Min(150, Model.Description.Length)]..." />
    <meta property="og:title" content="@Model.Title" />
    <meta property="og:description" content="@Model.PriceLabel — @Model.Location, @Model.City" />
    @if (primaryPhoto != null) { <meta property="og:image" content="@primaryPhoto" /> }
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #f8f9fa; }
        .hero { height: 420px; background: #dee2e6; position: relative; overflow: hidden; }
        .hero img { width: 100%; height: 100%; object-fit: cover; }
        .gallery-thumb { width: 80px; height: 60px; object-fit: cover; border-radius: 6px; cursor: pointer; border: 2px solid transparent; transition: border .15s; }
        .gallery-thumb.active { border-color: #185FA5; }
        .feature-pill { background: #f1f3f5; border-radius: 20px; padding: 4px 12px; font-size: 12px; color: #495057; display: inline-flex; align-items: center; gap: 5px; }
        .sticky-card { position: sticky; top: 20px; }
        .badge-available { background: #E1F5EE; color: #0F6E56; }
        .badge-sold { background: #FCEBEB; color: #A32D2D; }
    </style>
</head>
<body>
    <!-- Topbar -->
    <nav class="navbar bg-white border-bottom px-4 py-2">
        <span class="navbar-brand fw-semibold text-primary mb-0">RealEstate CRM</span>
        <span class="text-muted" style="font-size:12px;">Property Listing</span>
    </nav>

    <div class="container-lg py-4">
        <!-- Photo gallery -->
        <div class="hero rounded-3 mb-3" id="heroContainer">
            @if (primaryPhoto != null)
            { <img id="heroImg" src="@primaryPhoto" alt="@Model.Title" /> }
            else
            { <div class="d-flex align-items-center justify-content-center h-100 text-muted"><i class="bi bi-house-fill" style="font-size:60px;opacity:.2;"></i></div> }
            <div class="position-absolute top-0 end-0 m-3">
                <span class="badge px-3 py-2 fs-6 @(Model.Status=="Available"?"badge-available":"badge-sold")">@Model.Status</span>
            </div>
        </div>
        @if (Model.Photos.Count > 1)
        {
            <div class="d-flex gap-2 mb-4 flex-wrap">
                @foreach (var ph in Model.Photos)
                {
                    <img src="@ph.FilePath" class="gallery-thumb @(ph.IsPrimary?"active":"")"
                         onclick="switchPhoto(this, '@ph.FilePath')" alt="photo" />
                }
            </div>
        }

        <div class="row g-4">
            <!-- Left: property info -->
            <div class="col-lg-8">
                <div class="bg-white rounded-3 p-4 shadow-sm mb-4">
                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-2">
                        <h2 class="fw-semibold mb-0" style="font-size:22px;">@Model.Title</h2>
                        <div class="text-primary fw-bold fs-4">@Model.PriceLabel</div>
                    </div>
                    <p class="text-muted mb-3"><i class="bi bi-geo-alt me-1"></i>@Model.Address, @Model.City</p>

                    <!-- Key features -->
                    <div class="d-flex flex-wrap gap-2 mb-4">
                        <span class="feature-pill"><i class="bi bi-house"></i>@Model.PropertyType</span>
                        <span class="feature-pill"><i class="bi bi-door-open"></i>@Model.Bedrooms Bedrooms</span>
                        <span class="feature-pill"><i class="bi bi-droplet"></i>@Model.Bathrooms Bathrooms</span>
                        <span class="feature-pill"><i class="bi bi-arrows-angle-expand"></i>@Model.AreaSqFt sqft</span>
                        @if (Model.Floors > 0) { <span class="feature-pill"><i class="bi bi-building"></i>Floor @Model.Floors</span> }
                        @if (Model.YearBuilt > 0) { <span class="feature-pill"><i class="bi bi-calendar"></i>Built @Model.YearBuilt</span> }
                        @if (Model.IsFurnished) { <span class="feature-pill"><i class="bi bi-sofa"></i>Furnished</span> }
                        @if (Model.HasParking) { <span class="feature-pill"><i class="bi bi-car-front"></i>Parking</span> }
                        @if (Model.HasGym) { <span class="feature-pill"><i class="bi bi-activity"></i>Gym</span> }
                        @if (Model.HasPool) { <span class="feature-pill"><i class="bi bi-droplet-half"></i>Pool</span> }
                        @if (Model.HasSecurity) { <span class="feature-pill"><i class="bi bi-shield-check"></i>24/7 Security</span> }
                    </div>

                    <h5 class="fw-semibold mb-2" style="font-size:15px;">About This Property</h5>
                    <p style="font-size:14px;line-height:1.7;color:#495057;">@Model.Description</p>

                    @if (Model.Amenities.Any())
                    {
                        <h5 class="fw-semibold mb-2 mt-3" style="font-size:15px;">Amenities</h5>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var a in Model.Amenities)
                            { <span class="badge bg-light text-dark border">@a</span> }
                        </div>
                    }
                </div>

                <!-- Enquiry form -->
                <div class="bg-white rounded-3 p-4 shadow-sm" id="enquireSection">
                    <h5 class="fw-semibold mb-3">Send an Enquiry</h5>
                    @if (TempData["EnquirySuccess"] != null)
                    {
                        <div class="alert alert-success"><i class="bi bi-check-circle me-2"></i>@TempData["EnquirySuccess"]</div>
                    }
                    <form asp-controller="PublicProperty" asp-action="Enquire" asp-route-slug="@Model.Slug" method="post">
                        @Html.AntiForgeryToken()
                        <div class="row g-3">
                            <div class="col-md-6"><label class="form-label">Your Name *</label><input name="ClientName" class="form-control" required /></div>
                            <div class="col-md-6"><label class="form-label">Phone Number *</label><input name="ClientPhone" class="form-control" type="tel" required /></div>
                            <div class="col-12"><label class="form-label">Email</label><input name="ClientEmail" class="form-control" type="email" /></div>
                            <div class="col-12"><label class="form-label">Message</label><textarea name="Message" class="form-control" rows="2" placeholder="Tell us what you're looking for..."></textarea></div>
                            <div class="col-12"><button type="submit" class="btn btn-outline-primary w-100"><i class="bi bi-envelope me-1"></i>Send Enquiry</button></div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Right: sticky CTA -->
            <div class="col-lg-4">
                <div class="sticky-card">
                    <!-- Agent card -->
                    <div class="bg-white rounded-3 p-4 shadow-sm mb-3">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold" style="width:44px;height:44px;background:#185FA5;font-size:16px;">@(Model.AgentName.FirstOrDefault())</div>
                            <div>
                                <div class="fw-semibold">@Model.AgentName</div>
                                <div class="text-muted" style="font-size:12px;">Your Property Advisor</div>
                            </div>
                        </div>
                        <a href="tel:@Model.AgentPhone" class="btn btn-outline-primary w-100 mb-2"><i class="bi bi-telephone me-1"></i>Call Agent</a>
                        <a href="https://wa.me/@Model.AgentPhone.Replace(" ","").Replace("+",""))" target="_blank" class="btn btn-success w-100 mb-2"><i class="bi bi-whatsapp me-1"></i>WhatsApp</a>
                        <a href="#enquireSection" class="btn btn-outline-secondary w-100"><i class="bi bi-envelope me-1"></i>Send Enquiry</a>
                    </div>

                    <!-- Deal CTA — only show if Available -->
                    @if (Model.Status == "Available")
                    {
                        <div class="rounded-3 p-4 text-center" style="background:#E6F1FB;border:2px solid #185FA5;">
                            <div class="fw-semibold text-primary mb-1" style="font-size:15px;">Ready to buy?</div>
                            <p class="text-muted mb-3" style="font-size:13px;">Submit your deal confirmation and our team will get back to you within 24 hours.</p>
                            <a asp-controller="PublicProperty" asp-action="Confirm" asp-route-slug="@Model.Slug"
                               class="btn btn-primary w-100">
                                <i class="bi bi-handshake me-1"></i>Confirm Deal Interest
                            </a>
                            <small class="text-muted d-block mt-2" style="font-size:11px;">
                                <i class="bi bi-shield-lock me-1"></i>Secure · No payment required
                            </small>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <footer class="border-top mt-5 py-3 text-center text-muted" style="font-size:12px;">
        © RealEstate CRM — This listing is shared by @Model.AgentName
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function switchPhoto(el, src) {
            document.getElementById('heroImg').src = src;
            document.querySelectorAll('.gallery-thumb').forEach(t => t.classList.remove('active'));
            el.classList.add('active');
        }
    </script>
</body>
</html>
