@model ConfirmationSuccessViewModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Confirmation Received</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>body{font-family:'Segoe UI',sans-serif;background:#f8f9fa;}</style>
</head>
<body>
    <nav class="navbar bg-white border-bottom px-4 py-2">
        <span class="navbar-brand fw-semibold text-primary mb-0">RealEstate CRM</span>
    </nav>
    <div class="container d-flex align-items-center justify-content-center" style="min-height:85vh;">
        <div class="text-center" style="max-width:480px;">
            <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto mb-4 text-white" style="width:80px;height:80px;background:#0F6E56;font-size:36px;">
                <i class="bi bi-check-lg"></i>
            </div>
            <h2 class="fw-semibold mb-2">Confirmation Received!</h2>
            <p class="text-muted mb-4">Thank you, <strong>@Model.ClientName</strong>. Your deal interest for <strong>@Model.PropertyTitle</strong> has been submitted successfully.</p>

            <div class="bg-white rounded-3 p-4 shadow-sm mb-4 text-start">
                <div class="text-muted mb-1" style="font-size:12px;text-transform:uppercase;letter-spacing:.07em;">Your Reference Number</div>
                <code class="fs-6 text-primary">@Model.ConfirmationToken[..8].ToUpper()</code>
                <div class="text-muted mt-1" style="font-size:11px;">Save this for your records</div>
            </div>

            <div class="bg-white rounded-3 p-4 shadow-sm mb-4 text-start">
                <h6 class="fw-semibold mb-3">What happens next?</h6>
                <div class="d-flex gap-3 mb-2"><div class="rounded-circle text-white d-flex align-items-center justify-content-center flex-shrink-0" style="width:28px;height:28px;background:#185FA5;font-size:12px;">1</div><div style="font-size:13px;">Our agent will review your confirmation within <strong>24 hours</strong></div></div>
                <div class="d-flex gap-3 mb-2"><div class="rounded-circle text-white d-flex align-items-center justify-content-center flex-shrink-0" style="width:28px;height:28px;background:#185FA5;font-size:12px;">2</div><div style="font-size:13px;">You will receive a call from <strong>@Model.AgentPhone</strong> to discuss details</div></div>
                <div class="d-flex gap-3"><div class="rounded-circle text-white d-flex align-items-center justify-content-center flex-shrink-0" style="width:28px;height:28px;background:#185FA5;font-size:12px;">3</div><div style="font-size:13px;">If approved, the property will be reserved for you</div></div>
            </div>

            @if (!string.IsNullOrEmpty(Model.AgentPhone))
            {
                <a href="https://wa.me/@Model.AgentPhone.Replace(" ","").Replace("+","")?text=Hi,%20I%20submitted%20a%20deal%20confirmation%20(Ref:%20@Model.ConfirmationToken[..8].ToUpper())%20for%20@Uri.EscapeDataString(Model.PropertyTitle)"
                   target="_blank" class="btn btn-success mb-2 w-100">
                    <i class="bi bi-whatsapp me-1"></i>Message Agent on WhatsApp
                </a>
            }
            <p class="text-muted" style="font-size:11px;"><i class="bi bi-info-circle me-1"></i>This confirmation is not legally binding. The property remains available until formally agreed.</p>
        </div>
    </div>
</body>
</html>
