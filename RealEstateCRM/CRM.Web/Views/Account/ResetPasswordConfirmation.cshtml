@* ResetPasswordConfirmation.cshtml *@
@{ Layout = null; }
<!DOCTYPE html><html lang="en"><head>
<meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Password Reset — RealEstate CRM</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
<style>body{background:#f0f4f8;font-family:'Segoe UI',sans-serif;min-height:100vh;display:flex;align-items:center;justify-content:center;}.auth-card{background:#fff;border-radius:16px;padding:40px;width:100%;max-width:420px;text-align:center;box-shadow:0 4px 24px rgba(0,0,0,.08);}</style>
</head><body>
<div class="auth-card">
    <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto mb-4" style="width:64px;height:64px;background:#E1F5EE;">
        <i class="bi bi-check-lg" style="font-size:28px;color:#0F6E56;"></i>
    </div>
    <h5 class="fw-semibold mb-2">Password Reset Successful</h5>
    <p style="font-size:14px;color:#6c757d;line-height:1.7;">Your password has been updated. You can now sign in with your new password.</p>
    <a asp-action="Login" class="btn btn-primary mt-3" style="background:#185FA5;border:none;border-radius:8px;padding:10px 28px;font-weight:500;"><i class="bi bi-box-arrow-in-right me-1"></i>Sign In</a>
</div>
</body></html>
