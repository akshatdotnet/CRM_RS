@* ──────────────────────────────────────── *@
@* ForgotPassword.cshtml *@
@model ForgotPasswordViewModel
@{ Layout = null; }
<!DOCTYPE html><html lang="en"><head>
<meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Forgot Password — RealEstate CRM</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
<style>body{background:#f0f4f8;font-family:'Segoe UI',sans-serif;min-height:100vh;display:flex;align-items:center;justify-content:center;}.auth-card{background:#fff;border-radius:16px;padding:40px;width:100%;max-width:420px;box-shadow:0 4px 24px rgba(0,0,0,.08);border:1px solid #e9ecef;}.form-control{border-radius:8px;font-size:14px;border-color:#dee2e6;padding:10px 14px;}.form-control:focus{border-color:#185FA5;box-shadow:0 0 0 3px rgba(24,95,165,.12);}.btn-primary{background:#185FA5;border:none;border-radius:8px;padding:11px;font-weight:500;}</style>
</head><body>
<div class="auth-card">
    <div style="font-size:22px;font-weight:600;color:#185FA5;margin-bottom:4px;"><i class="bi bi-buildings me-2"></i>RealEstate CRM</div>
    <div style="font-size:12px;color:#adb5bd;margin-bottom:28px;">Reset your password</div>
    <p style="font-size:14px;color:#555;margin-bottom:20px;line-height:1.6;">Enter your email and we'll send you a password reset link. The link expires in 1 hour.</p>
    <form asp-action="ForgotPassword" method="post">
        @Html.AntiForgeryToken()
        <div class="mb-3">
            <label class="form-label" style="font-size:13px;font-weight:500;">Email Address</label>
            <input asp-for="Email" type="email" class="form-control" placeholder="you@company.com" autofocus />
            <span asp-validation-for="Email" class="text-danger" style="font-size:12px;"></span>
        </div>
        <button type="submit" class="btn btn-primary w-100 mb-3"><i class="bi bi-send me-1"></i>Send Reset Link</button>
        <div class="text-center"><a asp-action="Login" style="font-size:13px;color:#185FA5;text-decoration:none;"><i class="bi bi-arrow-left me-1"></i>Back to Sign In</a></div>
    </form>
</div>
<script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>
</body></html>
