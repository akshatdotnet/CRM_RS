@{ Layout = null; }
<!DOCTYPE html><html lang="en"><head>
<meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Access Denied — RealEstate CRM</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
<style>body{background:#f0f4f8;font-family:'Segoe UI',sans-serif;min-height:100vh;display:flex;align-items:center;justify-content:center;}</style>
</head><body>
<div style="background:#fff;border-radius:16px;padding:40px;width:100%;max-width:420px;text-align:center;box-shadow:0 4px 24px rgba(0,0,0,.08);border:1px solid #e9ecef;">
    <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto mb-4" style="width:64px;height:64px;background:#FAEEDA;">
        <i class="bi bi-exclamation-triangle" style="font-size:28px;color:#854F0B;"></i>
    </div>
    <h5 class="fw-semibold mb-2">Access Denied</h5>
    <p style="font-size:14px;color:#6c757d;line-height:1.7;">You don't have permission to access this page. Contact your administrator if you believe this is an error.</p>
    <a href="/" class="btn btn-primary mt-2 me-2" style="background:#185FA5;border:none;border-radius:8px;font-size:14px;"><i class="bi bi-house me-1"></i>Dashboard</a>
    <a asp-action="Profile" asp-controller="Account" class="btn btn-outline-secondary mt-2" style="border-radius:8px;font-size:14px;">My Profile</a>
</div>
</body></html>
