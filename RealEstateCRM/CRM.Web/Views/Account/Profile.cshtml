@model ProfileViewModel
@{ ViewData["Title"] = "My Profile"; ViewData["Breadcrumb"] = "My Profile"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-semibold">My Profile</h4>
    <a asp-action="ChangePassword" class="btn btn-sm btn-outline-primary">
        <i class="bi bi-key me-1"></i>Change Password
    </a>
</div>

<div class="row">
    <div class="col-md-5">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <div class="d-flex align-items-center gap-3 mb-4">
                    <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold"
                         style="width:56px;height:56px;background:#185FA5;font-size:20px;">
                        @(Model.FullName.Split(' ').Take(2).Select(n=>n[0]).Aggregate("",(a,b)=>a+b))
                    </div>
                    <div>
                        <div class="fw-semibold fs-5">@Model.FullName</div>
                        <span class="badge" style="background:#E6F1FB;color:#185FA5;font-size:12px;">@Model.Role</span>
                    </div>
                </div>
                <table class="w-100" style="font-size:13px;">
                    <tr><td class="text-muted py-2" style="width:40%;">Email</td><td class="py-2">@Model.Email</td></tr>
                    <tr><td class="text-muted py-2">Role</td><td class="py-2">@Model.Role</td></tr>
                    <tr><td class="text-muted py-2">Member since</td><td class="py-2">@Model.CreatedAt.ToString("MMM dd, yyyy")</td></tr>
                    <tr><td class="text-muted py-2">Last login</td><td class="py-2">@(Model.LastLoginAt?.ToString("MMM dd, yyyy hh:mm tt") ?? "First login")</td></tr>
                </table>
                <div class="mt-4 pt-3 border-top">
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger w-100">
                            <i class="bi bi-box-arrow-right me-1"></i>Sign Out
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
