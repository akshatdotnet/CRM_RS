@model UserListViewModel
@{ ViewData["Title"] = "User Management"; ViewData["Breadcrumb"] = "Users"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-semibold">User Management</h4>
    <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Add User</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th><th>Email</th><th>Role</th><th>Status</th><th>Last Login</th><th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model.Users)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold"
                                         style="width:32px;height:32px;font-size:12px;background:@(u.Role=="Admin"?"#185FA5":u.Role=="SeniorAgent"?"#534AB7":"#0F6E56");">
                                        @(u.FullName.Split(' ').Take(2).Select(n=>n[0]).Aggregate("",(a,b)=>a+b))
                                    </div>
                                    <span class="fw-medium">@u.FullName</span>
                                </div>
                            </td>
                            <td><small>@u.Email</small></td>
                            <td>
                                <span class="badge" style="font-size:11px;padding:3px 10px;
                                    background:@(u.Role=="Admin"?"#E6F1FB":u.Role=="SeniorAgent"?"#EEEDFE":"#E1F5EE");
                                    color:@(u.Role=="Admin"?"#185FA5":u.Role=="SeniorAgent"?"#534AB7":"#0F6E56");">
                                    @u.Role
                                </span>
                            </td>
                            <td>
                                @if (u.IsActive)
                                { <span class="badge bg-success" style="font-size:11px;">Active</span> }
                                else
                                { <span class="badge bg-secondary" style="font-size:11px;">Inactive</span> }
                            </td>
                            <td><small class="text-muted">@(u.LastLoginAt?.ToString("MMM dd, hh:mm tt") ?? "Never")</small></td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a asp-action="Edit" asp-route-id="@u.Id" class="btn btn-sm btn-outline-secondary" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="ResetUserPassword" asp-route-id="@u.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-warning" title="Send password reset"
                                                onclick="return confirm('Send password reset email to @u.Email?')">
                                            <i class="bi bi-key"></i>
                                        </button>
                                    </form>
                                    <form asp-action="ToggleActive" asp-route-id="@u.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm @(u.IsActive?"btn-outline-danger":"btn-outline-success")"
                                                title="@(u.IsActive?"Deactivate":"Activate")"
                                                onclick="return confirm('@(u.IsActive?"Deactivate":"Activate") this user?')">
                                            <i class="bi bi-@(u.IsActive?"person-x":"person-check")"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
