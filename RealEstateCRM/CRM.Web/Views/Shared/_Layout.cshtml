@using Microsoft.AspNetCore.Identity
@using CRM.Core.Entities
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserMgr

@{
    var user = SignInManager.IsSignedIn(User) ? await UserMgr.GetUserAsync(User) : null;
    var userRoles = user != null ? await UserMgr.GetRolesAsync(user) : new List<string>();
    var userRole = userRoles.FirstOrDefault() ?? "";
    var isAdmin = userRole == AppRoles.Admin;
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RealEstate CRM</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
<div class="d-flex">
    <nav class="sidebar d-flex flex-column" style="width:230px;min-height:100vh;background:#fff;border-right:1px solid #e9ecef;position:fixed;top:0;left:0;z-index:100;">
        <div class="p-3 border-bottom">
            <div class="d-flex align-items-center gap-2">
                <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold" style="width:36px;height:36px;background:#185FA5;font-size:14px;flex-shrink:0;">RE</div>
                <div>
                    <div class="fw-semibold" style="font-size:14px;">RealEstate CRM</div>
                    <div class="text-muted" style="font-size:11px;">Enterprise Edition</div>
                </div>
            </div>
        </div>
        @if (user != null)
        {
            <div class="px-3 py-2 border-bottom" style="background:#f8f9fa;">
                <div class="d-flex align-items-center gap-2">
                    <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold" style="width:28px;height:28px;font-size:10px;flex-shrink:0;background:@(isAdmin?"#185FA5":userRole=="SeniorAgent"?"#534AB7":"#0F6E56");">
                        @(user.FullName.Split(' ').Take(2).Select(n=>n[0]).Aggregate("",(a,b)=>a+b))
                    </div>
                    <div style="overflow:hidden;">
                        <div style="font-size:12px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@user.FullName</div>
                        <div style="font-size:10px;color:#adb5bd;">@userRole</div>
                    </div>
                </div>
            </div>
        }
        <div class="flex-grow-1 py-2">
            <div class="px-3 py-1 text-uppercase text-muted" style="font-size:10px;letter-spacing:.08em;">Main</div>
            <a asp-controller="Home" asp-action="Index" class="nav-link-item @(ctrl=="Home"?"active":"")"><i class="bi bi-grid-fill"></i> Dashboard</a>
            <a asp-controller="Lead" asp-action="Pipeline" class="nav-link-item @(ctrl=="Lead"&&action=="Pipeline"?"active":"")"><i class="bi bi-kanban-fill"></i> Pipeline</a>
            <a asp-controller="Lead" asp-action="Index" class="nav-link-item @(ctrl=="Lead"&&action!="Pipeline"&&action!="Create"?"active":"")"><i class="bi bi-people-fill"></i> All Leads</a>
            <a asp-controller="Customer" asp-action="Index" class="nav-link-item @(ctrl=="Customer"?"active":"")"><i class="bi bi-person-check-fill"></i> Customers</a>
            <a asp-controller="Property" asp-action="Index" class="nav-link-item @(ctrl=="Property"?"active":"")"><i class="bi bi-buildings-fill"></i> Properties</a>
            <a asp-controller="Lead" asp-action="Create" class="nav-link-item @(ctrl=="Lead"&&action=="Create"?"active":"")"><i class="bi bi-plus-circle-fill"></i> Add Lead</a>
            <div class="px-3 py-1 text-uppercase text-muted mt-2" style="font-size:10px;letter-spacing:.08em;">Reports</div>
            <a asp-controller="Analytics" asp-action="Index" class="nav-link-item @(ctrl=="Analytics"?"active":"")"><i class="bi bi-bar-chart-fill"></i> Analytics</a>
            @if (isAdmin)
            {
                <div class="px-3 py-1 text-uppercase text-muted mt-2" style="font-size:10px;letter-spacing:.08em;">Admin</div>
                <a asp-controller="UserManagement" asp-action="Index" class="nav-link-item @(ctrl=="UserManagement"?"active":"")"><i class="bi bi-person-gear"></i> Users & Roles</a>
            }
        </div>
        <div class="border-top" style="padding:8px 0;">
            <a asp-controller="Account" asp-action="Profile" class="nav-link-item @(ctrl=="Account"?"active":"")"><i class="bi bi-person-circle"></i> My Profile</a>
            <form asp-controller="Account" asp-action="Logout" method="post" class="w-100">
                @Html.AntiForgeryToken()
                <button type="submit" style="display:flex;align-items:center;gap:10px;padding:9px 16px;font-size:13px;color:#dc3545;width:100%;background:none;border:none;cursor:pointer;text-align:left;">
                    <i class="bi bi-box-arrow-right"></i> Sign Out
                </button>
            </form>
        </div>
    </nav>

    <main style="margin-left:230px;flex:1;min-height:100vh;background:#f8f9fa;">
        <div class="topbar border-bottom bg-white px-4 py-2 d-flex align-items-center justify-content-between" style="position:sticky;top:0;z-index:50;">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0" style="font-size:13px;">
                    <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Home</a></li>
                    @if (ViewData["Breadcrumb"] != null) { <li class="breadcrumb-item active">@ViewData["Breadcrumb"]</li> }
                </ol>
            </nav>
            <div class="d-flex align-items-center gap-3">
                @if (user != null)
                { <span style="font-size:12px;color:#adb5bd;"><i class="bi bi-circle-fill text-success me-1" style="font-size:8px;"></i>@user.FullName</span> }
                <a asp-controller="Lead" asp-action="Create" class="btn btn-sm btn-primary"><i class="bi bi-plus"></i> New Lead</a>
            </div>
        </div>
        <div class="px-4 pt-3">
            @if (TempData["Success"] != null)
            { <div class="alert alert-success alert-dismissible fade show" style="font-size:13px;"><i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
            @if (TempData["Error"] != null)
            { <div class="alert alert-danger alert-dismissible fade show" style="font-size:13px;"><i class="bi bi-exclamation-circle-fill me-2"></i>@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
        </div>
        <div class="p-4">@RenderBody()</div>
    </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
