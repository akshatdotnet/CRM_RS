@model PropertyFormViewModel
@{ ViewData["Title"] = "Edit Property"; ViewData["Breadcrumb"] = "Edit Property"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-semibold">Edit — @Model.Title</h4>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

<form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <div class="row g-3">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="text-muted fw-semibold mb-3" style="font-size:11px;text-transform:uppercase;letter-spacing:.07em;">Basic Information</h6>
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">Property Title <span class="text-danger">*</span></label>
                            <input asp-for="Title" class="form-control" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Property Type</label>
                            <select asp-for="PropertyType" class="form-select">
                                @foreach (var t in new[]{"1BHK","2BHK","3BHK","4BHK","5BHK","Villa","Penthouse","Row House","Plot","Commercial Office","Shop"})
                                { <option>@t</option> }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Status</label>
                            <select asp-for="Status" class="form-select">
                                <option>Available</option><option>Hold</option><option>Sold</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="text-muted fw-semibold mb-3" style="font-size:11px;text-transform:uppercase;letter-spacing:.07em;">Location</h6>
                    <div class="row g-3">
                        <div class="col-md-6"><label class="form-label">Locality / Area</label><input asp-for="Location" class="form-control" /></div>
                        <div class="col-md-6"><label class="form-label">City</label><input asp-for="City" class="form-control" /></div>
                        <div class="col-12"><label class="form-label">Full Address</label><input asp-for="Address" class="form-control" /></div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="text-muted fw-semibold mb-3" style="font-size:11px;text-transform:uppercase;letter-spacing:.07em;">Property Details</h6>
                    <div class="row g-3">
                        <div class="col-md-3"><label class="form-label">Bedrooms</label><input asp-for="Bedrooms" type="number" class="form-control" min="0" /></div>
                        <div class="col-md-3"><label class="form-label">Bathrooms</label><input asp-for="Bathrooms" type="number" class="form-control" min="0" /></div>
                        <div class="col-md-3"><label class="form-label">Floors</label><input asp-for="Floors" type="number" class="form-control" min="0" /></div>
                        <div class="col-md-3"><label class="form-label">Year Built</label><input asp-for="YearBuilt" type="number" class="form-control" /></div>
                        <div class="col-md-6"><label class="form-label">Area (sq ft)</label><input asp-for="AreaSqFt" type="number" class="form-control" step="0.5" /></div>
                        <div class="col-md-6"><label class="form-label">Amenities (comma-separated)</label><input asp-for="Amenities" class="form-control" /></div>
                    </div>
                    <div class="row g-2 mt-2">
                        @foreach (var (prop, label) in new[]{("IsFurnished","Furnished"),("HasParking","Parking"),("HasGym","Gym"),("HasPool","Pool"),("HasSecurity","24/7 Security")})
                        {
                            <div class="col-md-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="@prop" id="@prop" value="true" />
                                    <label class="form-check-label" for="@prop">@label</label>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="text-muted fw-semibold mb-2" style="font-size:11px;text-transform:uppercase;letter-spacing:.07em;">Add More Photos</h6>
                    <input type="file" name="Photos" multiple accept=".jpg,.jpeg,.png,.webp" class="form-control" />
                    <small class="text-muted">JPG, PNG, WEBP — Max 5MB each. Existing photos managed from Details page.</small>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="text-muted fw-semibold mb-3" style="font-size:11px;text-transform:uppercase;letter-spacing:.07em;">Pricing</h6>
                    <div class="mb-3">
                        <label class="form-label">Price (₹) <span class="text-danger">*</span></label>
                        <input asp-for="Price" type="number" class="form-control" />
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Price Display Label</label>
                        <input asp-for="PriceLabel" class="form-control" placeholder="e.g. ₹1.8 Cr" />
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="text-muted fw-semibold mb-3" style="font-size:11px;text-transform:uppercase;letter-spacing:.07em;">Agent & Publishing</h6>
                    <div class="mb-3">
                        <label class="form-label">Listing Agent</label>
                        <select asp-for="CreatedByAgentId" class="form-select">
                            @foreach (var a in Model.Agents)
                            { <option value="@a.Id">@a.FullName</option> }
                        </select>
                    </div>
                    <div class="form-check form-switch">
                        <input asp-for="IsPublished" class="form-check-input" type="checkbox" role="switch" />
                        <label class="form-check-label">Published (visible to clients)</label>
                    </div>
                </div>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Save Changes</button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="mt-2">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-danger w-100" onclick="return confirm('Delete this property permanently?')">
                        <i class="bi bi-trash me-1"></i>Delete Property
                    </button>
                </form>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
