@model PropertyFormViewModel
@{ ViewData["Title"] = "Add Property"; ViewData["Breadcrumb"] = "Add Property"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-semibold">Add New Property</h4>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <div class="row g-3">
        <div class="col-md-8">
            <!-- Basic Info -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="text-muted fw-semibold mb-3" style="font-size:11px;text-transform:uppercase;letter-spacing:.07em;">Basic Information</h6>
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">Property Title <span class="text-danger">*</span></label>
                            <input asp-for="Title" class="form-control" placeholder="e.g. Spacious 3BHK with Sea View at Juhu" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Property Type <span class="text-danger">*</span></label>
                            <select asp-for="PropertyType" class="form-select">
                                <option value="">-- Select --</option>
                                @foreach (var t in new[]{"1BHK","2BHK","3BHK","4BHK","5BHK","Villa","Penthouse","Row House","Plot","Commercial Office","Shop"})
                                { <option>@t</option> }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Status</label>
                            <select asp-for="Status" class="form-select">
                                <option>Available</option><option>Hold</option><option>Sold</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Describe the property in detail — layout, surroundings, USPs..."></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Location -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="text-muted fw-semibold mb-3" style="font-size:11px;text-transform:uppercase;letter-spacing:.07em;">Location</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Locality / Area <span class="text-danger">*</span></label>
                            <input asp-for="Location" class="form-control" placeholder="e.g. Andheri West" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">City</label>
                            <input asp-for="City" class="form-control" placeholder="e.g. Mumbai" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Full Address <span class="text-danger">*</span></label>
                            <input asp-for="Address" class="form-control" placeholder="Flat no., Building, Street, Area, City – PIN" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Property Details -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="text-muted fw-semibold mb-3" style="font-size:11px;text-transform:uppercase;letter-spacing:.07em;">Property Details</h6>
                    <div class="row g-3">
                        <div class="col-md-3"><label class="form-label">Bedrooms</label><input asp-for="Bedrooms" type="number" class="form-control" min="0" /></div>
                        <div class="col-md-3"><label class="form-label">Bathrooms</label><input asp-for="Bathrooms" type="number" class="form-control" min="0" /></div>
                        <div class="col-md-3"><label class="form-label">Floors</label><input asp-for="Floors" type="number" class="form-control" min="0" /></div>
                        <div class="col-md-3"><label class="form-label">Year Built</label><input asp-for="YearBuilt" type="number" class="form-control" /></div>
                        <div class="col-md-6"><label class="form-label">Area (sq ft)</label><input asp-for="AreaSqFt" type="number" class="form-control" step="0.5" /></div>
                        <div class="col-md-6"><label class="form-label">Amenities (comma separated)</label><input asp-for="Amenities" class="form-control" placeholder="Club House, Garden, Power Backup" /></div>
                    </div>
                    <!-- Checkboxes -->
                    <div class="row g-2 mt-2">
                        @foreach (var (field, label, icon) in new[]{("IsFurnished","Furnished","sofa"),("HasParking","Parking","car-front"),("HasGym","Gym","activity"),("HasPool","Swimming Pool","droplet"),("HasSecurity","24/7 Security","shield-check")})
                        {
                            <div class="col-md-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="@field" id="@field" value="true" />
                                    <label class="form-check-label" for="@field"><i class="bi bi-@icon me-1"></i>@label</label>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Photos -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="text-muted fw-semibold mb-3" style="font-size:11px;text-transform:uppercase;letter-spacing:.07em;">Property Photos</h6>
                    <div class="border border-dashed rounded-3 p-4 text-center" style="border-style:dashed!important;cursor:pointer;" onclick="document.getElementById('photoInput').click()">
                        <i class="bi bi-cloud-upload text-muted" style="font-size:32px;"></i>
                        <p class="text-muted mb-1 mt-2">Click to upload photos or drag & drop</p>
                        <small class="text-muted">JPG, PNG, WEBP — Max 5MB each — First photo becomes cover image</small>
                    </div>
                    <input type="file" id="photoInput" name="Photos" multiple accept=".jpg,.jpeg,.png,.webp" class="d-none" onchange="previewPhotos(this)" />
                    <div id="photoPreview" class="d-flex flex-wrap gap-2 mt-3"></div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <!-- Pricing -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="text-muted fw-semibold mb-3" style="font-size:11px;text-transform:uppercase;letter-spacing:.07em;">Pricing</h6>
                    <div class="mb-3">
                        <label class="form-label">Price (₹) <span class="text-danger">*</span></label>
                        <input asp-for="Price" type="number" class="form-control" placeholder="e.g. 18000000" />
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Price Display Label</label>
                        <input asp-for="PriceLabel" class="form-control" placeholder="e.g. ₹1.8 Cr" />
                        <small class="text-muted">Shown on public page (e.g. ₹85L, ₹1.8 Cr)</small>
                    </div>
                </div>
            </div>

            <!-- Assignment -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="text-muted fw-semibold mb-3" style="font-size:11px;text-transform:uppercase;letter-spacing:.07em;">Agent & Publishing</h6>
                    <div class="mb-3">
                        <label class="form-label">Listing Agent</label>
                        <select asp-for="CreatedByAgentId" class="form-select">
                            @foreach (var a in Model.Agents)
                            { <option value="@a.Id">@a.FullName</option> }
                        </select>
                    </div>
                    <div class="form-check form-switch">
                        <input asp-for="IsPublished" class="form-check-input" type="checkbox" role="switch" id="isPublished" />
                        <label class="form-check-label" for="isPublished">Publish (visible on public URL)</label>
                    </div>
                </div>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Save Property</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function previewPhotos(input) {
            const preview = document.getElementById('photoPreview');
            preview.innerHTML = '';
            Array.from(input.files).forEach((file, i) => {
                const reader = new FileReader();
                reader.onload = e => {
                    const div = document.createElement('div');
                    div.style.cssText = 'position:relative;width:100px;height:80px;';
                    div.innerHTML = `<img src="${e.target.result}" style="width:100%;height:100%;object-fit:cover;border-radius:8px;border:2px solid ${i===0?'#185FA5':'#dee2e6'}">
                        ${i===0?'<span style="position:absolute;bottom:3px;left:3px;background:#185FA5;color:#fff;font-size:9px;padding:1px 5px;border-radius:4px;">Cover</span>':''}`;
                    preview.appendChild(div);
                };
                reader.readAsDataURL(file);
            });
        }
    </script>
}
