@model PropertyDetailViewModel
@{ ViewData["Title"] = Model.Title; ViewData["Breadcrumb"] = "Property Details"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-semibold">@Model.Title</h4>
        <small class="text-muted">@Model.Location, @Model.City · @Model.Status</small>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil me-1"></i>Edit</a>
        <a href="/p/@Model.PublicSlug" target="_blank" class="btn btn-sm btn-outline-success"><i class="bi bi-box-arrow-up-right me-1"></i>Public Page</a>
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
    </div>
</div>

<!-- Share URL banner -->
<div class="alert mb-4" style="background:#E6F1FB;border:none;border-left:4px solid #185FA5;">
    <div class="d-flex align-items-center justify-content-between">
        <div>
            <div class="fw-semibold text-primary mb-1"><i class="bi bi-link-45deg me-1"></i>Agent Shareable URL</div>
            <code id="shareUrl" style="font-size:13px;">@Model.ShareableUrl</code>
            <small class="text-muted ms-2">— Share this link directly with your client</small>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-sm btn-outline-primary" onclick="copyUrl()"><i class="bi bi-clipboard me-1"></i>Copy</button>
            <a href="https://wa.me/?text=Check+out+this+property:+@Uri.EscapeDataString(Model.ShareableUrl)" target="_blank" class="btn btn-sm btn-success"><i class="bi bi-whatsapp me-1"></i>WhatsApp</a>
        </div>
    </div>
</div>

<div class="row g-3">
    <!-- Photos -->
    <div class="col-md-7">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="fw-semibold mb-0">Photos (@Model.Photos.Count)</h6>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-secondary"><i class="bi bi-plus me-1"></i>Add Photos</a>
                </div>
                <div class="row g-2">
                    @foreach (var ph in Model.Photos)
                    {
                        <div class="col-md-4 col-6">
                            <div style="position:relative;">
                                <img src="@ph.FilePath" style="width:100%;height:120px;object-fit:cover;border-radius:8px;border:2px solid @(ph.IsPrimary?"#185FA5":"#dee2e6")" />
                                @if (ph.IsPrimary) { <span class="badge bg-primary" style="position:absolute;bottom:5px;left:5px;font-size:10px;">Cover</span> }
                                <div style="position:absolute;top:5px;right:5px;display:flex;gap:3px;">
                                    @if (!ph.IsPrimary)
                                    {
                                        <form asp-action="SetPrimaryPhoto" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="photoId" value="@ph.Id" />
                                            <input type="hidden" name="propertyId" value="@Model.Id" />
                                            <button type="submit" class="btn btn-xs" style="padding:2px 5px;background:rgba(255,255,255,.9);font-size:10px;" title="Set as cover"><i class="bi bi-star"></i></button>
                                        </form>
                                    }
                                    <form asp-action="DeletePhoto" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="photoId" value="@ph.Id" />
                                        <input type="hidden" name="propertyId" value="@Model.Id" />
                                        <button type="submit" class="btn btn-xs" style="padding:2px 5px;background:rgba(255,255,255,.9);font-size:10px;color:#dc3545;" onclick="return confirm('Delete this photo?')"><i class="bi bi-trash"></i></button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                    @if (!Model.Photos.Any())
                    {
                        <div class="col-12 text-center text-muted py-3"><i class="bi bi-image" style="font-size:30px;opacity:.3;"></i><p class="small mt-1">No photos uploaded yet</p></div>
                    }
                </div>
            </div>
        </div>

        <!-- Enquiries -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <h6 class="fw-semibold mb-3">Client Enquiries (@Model.Enquiries.Count)</h6>
                @if (!Model.Enquiries.Any())
                { <p class="text-muted small">No enquiries yet.</p> }
                @foreach (var e in Model.Enquiries)
                {
                    <div class="d-flex justify-content-between align-items-start border-bottom pb-2 mb-2">
                        <div>
                            <div class="fw-medium" style="font-size:13px;">@e.ClientName</div>
                            <div class="text-muted" style="font-size:11px;">@e.ClientPhone · @e.ClientEmail</div>
                            <div style="font-size:12px;color:#495057;">@e.Message</div>
                            <div style="font-size:10px;color:#adb5bd;">@e.CreatedAt.ToString("MMM dd, yyyy hh:mm tt")</div>
                        </div>
                        <div class="d-flex flex-column gap-1 align-items-end">
                            <span class="badge @(e.Status=="New"?"bg-warning text-dark":e.Status=="Contacted"?"bg-info text-dark":"bg-success")" style="font-size:10px;">@e.Status</span>
                            @if (e.Status == "New")
                            {
                                <form asp-action="UpdateEnquiryStatus" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="enquiryId" value="@e.Id" />
                                    <input type="hidden" name="status" value="Contacted" />
                                    <input type="hidden" name="propertyId" value="@Model.Id" />
                                    <button type="submit" class="btn btn-xs btn-outline-secondary" style="font-size:10px;padding:2px 6px;">Mark Contacted</button>
                                </form>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Property info + Confirmations -->
    <div class="col-md-5">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <h6 class="fw-semibold mb-3">Property Info</h6>
                <table class="w-100" style="font-size:13px;">
                    <tr><td class="text-muted py-1">Type</td><td class="py-1">@Model.PropertyType</td></tr>
                    <tr><td class="text-muted py-1">Price</td><td class="py-1 fw-semibold text-primary">@Model.PriceLabel</td></tr>
                    <tr><td class="text-muted py-1">Area</td><td class="py-1">@Model.AreaSqFt sqft</td></tr>
                    <tr><td class="text-muted py-1">Bedrooms</td><td class="py-1">@Model.Bedrooms BHK</td></tr>
                    <tr><td class="text-muted py-1">Bathrooms</td><td class="py-1">@Model.Bathrooms</td></tr>
                    <tr><td class="text-muted py-1">Floors</td><td class="py-1">@Model.Floors</td></tr>
                    <tr><td class="text-muted py-1">Year Built</td><td class="py-1">@Model.YearBuilt</td></tr>
                    <tr><td class="text-muted py-1">Furnished</td><td class="py-1">@(Model.IsFurnished?"Yes":"No")</td></tr>
                    <tr><td class="text-muted py-1">Agent</td><td class="py-1">@Model.CreatedByAgent</td></tr>
                    <tr><td class="text-muted py-1">Published</td><td class="py-1"><span class="badge @(Model.IsPublished?"bg-success":"bg-secondary")">@(Model.IsPublished?"Yes":"No")</span></td></tr>
                </table>
                @if (Model.Amenities.Any())
                {
                    <div class="mt-2">
                        <div class="text-muted mb-1" style="font-size:12px;">Amenities</div>
                        <div class="d-flex flex-wrap gap-1">
                            @foreach (var a in Model.Amenities)
                            { <span class="badge bg-light text-dark border" style="font-size:11px;">@a</span> }
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Deal Confirmations -->
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h6 class="fw-semibold mb-3">Deal Confirmations (@Model.Confirmations.Count)</h6>
                @if (!Model.Confirmations.Any())
                { <p class="text-muted small">No confirmations submitted yet.</p> }
                @foreach (var c in Model.Confirmations)
                {
                    <div class="border rounded-3 p-2 mb-2" style="border-color:#dee2e6!important;">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="fw-medium" style="font-size:13px;">@c.ClientName</span>
                            <span class="badge @(c.Status=="Pending"?"bg-warning text-dark":c.Status=="Approved"?"bg-success":"bg-danger")" style="font-size:10px;">@c.Status</span>
                        </div>
                        <div class="text-muted" style="font-size:11px;">@c.ClientPhone · Offered: <strong class="text-dark">₹@((c.OfferedPrice/100000).ToString("N1"))L</strong> · @c.PaymentMode</div>
                        <div class="text-muted" style="font-size:10px;">@c.SubmittedAt.ToString("MMM dd, hh:mm tt")</div>
                        @if (c.Status == "Pending")
                        {
                            <div class="d-flex gap-2 mt-2">
                                <form asp-action="ReviewConfirmation" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="confirmationId" value="@c.Id" />
                                    <input type="hidden" name="status" value="Approved" />
                                    <input type="hidden" name="propertyId" value="@Model.Id" />
                                    <button class="btn btn-success btn-sm" style="font-size:11px;padding:2px 10px;">Approve</button>
                                </form>
                                <form asp-action="ReviewConfirmation" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="confirmationId" value="@c.Id" />
                                    <input type="hidden" name="status" value="Rejected" />
                                    <input type="hidden" name="propertyId" value="@Model.Id" />
                                    <button class="btn btn-outline-danger btn-sm" style="font-size:11px;padding:2px 10px;">Reject</button>
                                </form>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function copyUrl() {
    navigator.clipboard.writeText(document.getElementById('shareUrl').innerText);
    event.target.innerHTML = '<i class="bi bi-check me-1"></i>Copied!';
    setTimeout(() => event.target.innerHTML = '<i class="bi bi-clipboard me-1"></i>Copy', 2000);
}
</script>
}
