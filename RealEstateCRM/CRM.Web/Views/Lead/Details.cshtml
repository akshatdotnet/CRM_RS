@model LeadDetailViewModel
@{ ViewData["Title"] = Model.FullName; ViewData["Breadcrumb"] = "Lead Details"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-semibold">@Model.FullName</h4>
        <small class="text-muted">@Model.PropertyType · @Model.LocationPreference · @Model.DaysInPipeline days in pipeline</small>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary">
            <i class="bi bi-pencil me-1"></i>Edit
        </a>
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div class="row g-3">
    <!-- Lead Info -->
    <div class="col-md-4">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="avatar-circle" style="background:#E6F1FB;color:#185FA5;width:48px;height:48px;font-size:16px;">
                        @(Model.FullName.Split(' ').Take(2).Select(n => n[0]).Aggregate("", (a, b) => a + b))
                    </div>
                    <div>
                        <div class="fw-semibold">@Model.FullName</div>
                        <span class="badge-stage badge-@Model.Stage.Replace(" ","-")">@Model.Stage</span>
                    </div>
                </div>
                <table class="w-100" style="font-size:13px;">
                    <tr><td class="text-muted py-1">Phone</td><td class="py-1">@Model.Phone</td></tr>
                    <tr><td class="text-muted py-1">Email</td><td class="py-1">@Model.Email</td></tr>
                    <tr><td class="text-muted py-1">Source</td><td class="py-1">@Model.LeadSource</td></tr>
                    <tr><td class="text-muted py-1">Agent</td><td class="py-1">@Model.AgentName</td></tr>
                    <tr><td class="text-muted py-1">Created</td><td class="py-1">@Model.CreatedAt.ToString("MMM dd, yyyy")</td></tr>
                    <tr><td class="text-muted py-1">Follow-up</td><td class="py-1">@Model.FollowUpDeadline.ToString("MMM dd, yyyy")</td></tr>
                    <tr><td class="text-muted py-1">Close By</td><td class="py-1">@Model.CloseByDate.ToString("MMM dd, yyyy")</td></tr>
                    <tr><td class="text-muted py-1">Budget</td><td class="py-1">₹@((Model.BudgetMin/100000).ToString("N0"))L – ₹@((Model.BudgetMax/100000).ToString("N0"))L</td></tr>
                </table>
                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <div class="mt-3 p-2 rounded" style="background:#f8f9fa;font-size:12px;">
                        <div class="fw-medium mb-1">Notes</div>
                        @Model.Notes
                    </div>
                }
            </div>
        </div>

        <!-- Update Stage -->
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h6 class="fw-semibold mb-3">Update Stage</h6>
                @foreach (var s in new[]{"New","Contacted","Site Visit","Negotiation","Closed","Lost"})
                {
                    <form asp-action="UpdateStage" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="hidden" name="stage" value="@s" />
                        <button type="submit" class="btn btn-sm w-100 mb-1 @(Model.Stage==s?"btn-primary":"btn-outline-secondary")">
                            @s
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>

    <!-- Journey + Notes -->
    <div class="col-md-8">
        <!-- Lead Journey stages -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <h6 class="fw-semibold mb-3">Lead Journey</h6>
                <div class="d-flex gap-2 align-items-center flex-wrap">
                    @foreach (var s in new[]{"New","Contacted","Site Visit","Negotiation","Closed"})
                    {
                        var isActive = Model.Stage == s;
                        var isDone = Array.IndexOf(new[]{"New","Contacted","Site Visit","Negotiation","Closed"}, Model.Stage) >= Array.IndexOf(new[]{"New","Contacted","Site Visit","Negotiation","Closed"}, s);
                        <span class="badge-stage @(isDone ? "badge-"+s.Replace(" ","-") : "") px-3 py-2" style="@(!isDone?"background:#f8f9fa;color:#adb5bd;":"")">@s</span>
                        @if (s != "Closed") { <i class="bi bi-arrow-right text-muted"></i> }
                    }
                </div>
            </div>
        </div>

        <!-- Activity Timeline -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <h6 class="fw-semibold mb-3">Activity Timeline</h6>
                @if (!Model.Activities.Any())
                {
                    <p class="text-muted small">No activities logged yet.</p>
                }
                @foreach (var a in Model.Activities)
                {
                    var dotColor = a.ActivityType == "Stage Change" ? "#185FA5" : a.ActivityType == "Note" ? "#639922" : "#BA7517";
                    <div class="d-flex gap-3 mb-3">
                        <div class="d-flex flex-column align-items-center">
                            <div class="timeline-dot" style="background:@dotColor;"></div>
                        </div>
                        <div>
                            <div style="font-size:13px;font-weight:500;">@a.ActivityType</div>
                            <div style="font-size:12px;color:#6c757d;">@a.Description</div>
                            <div style="font-size:11px;color:#adb5bd;">@a.CreatedAt.ToString("MMM dd, yyyy hh:mm tt")</div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Add Note -->
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h6 class="fw-semibold mb-3">Add Note / Activity</h6>
                <form asp-action="AddNote" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-2">
                        <textarea name="note" class="form-control" rows="3" placeholder="Log a call, note, or update..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-sm btn-primary">
                        <i class="bi bi-plus me-1"></i>Add Note
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
