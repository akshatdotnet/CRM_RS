@model PipelineViewModel
@{ ViewData["Title"] = "Pipeline"; ViewData["Breadcrumb"] = "Pipeline"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-semibold">Lead Pipeline</h4>
        <small class="text-muted">Kanban board — click a card to view or update stage</small>
    </div>
    <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>New Lead</a>
</div>

<div class="d-flex gap-3 overflow-auto pb-3" style="align-items:flex-start;">
    @foreach (var stage in Model.Stages)
    {
        var headerClass = "ph-" + stage.Key.Replace(" ", "-");
        <div class="pipeline-col" style="min-width:210px;">
            <div class="pipeline-header @headerClass">
                <span>@stage.Key</span>
                <span class="badge bg-white text-dark" style="font-size:11px;">@stage.Value.Count</span>
            </div>
            @foreach (var card in stage.Value)
            {
                <div class="lead-card" onclick="window.location='/Lead/Details/@card.Id'">
                    <div style="font-size:13px;font-weight:500;">@card.FullName</div>
                    <div style="font-size:11px;color:#6c757d;">@card.PropertyType · @card.LocationPreference</div>
                    <div style="font-size:11px;color:#6c757d;">Budget: ₹@((card.BudgetMax/100000).ToString("N0"))L</div>
                    <div class="d-flex justify-content-between align-items-center mt-2">
                        <span style="font-size:10px;color:#adb5bd;">@card.LeadSource</span>
                        <span class="deadline-@card.DeadlineStatus">@card.FollowUpDeadline.ToString("MMM dd")</span>
                    </div>
                    <div style="font-size:10px;color:#adb5bd;margin-top:3px;">Agent: @card.AgentName</div>
                </div>
            }
            @if (!stage.Value.Any())
            {
                <div class="text-center py-3" style="font-size:12px;color:#adb5bd;border:1px dashed #dee2e6;border-radius:8px;">No leads</div>
            }
        </div>
    }
</div>
