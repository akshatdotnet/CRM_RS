@model LeadFormViewModel
@{ ViewData["Title"] = "Add New Lead"; ViewData["Breadcrumb"] = "Add Lead"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-semibold">Add New Lead</h4>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div class="row g-3">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="fw-semibold mb-3 text-muted" style="font-size:12px;text-transform:uppercase;letter-spacing:.05em;">Personal Details</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Full Name <span class="text-danger">*</span></label>
                            <input asp-for="FullName" class="form-control" placeholder="e.g. Ramesh Kumar" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Phone Number <span class="text-danger">*</span></label>
                            <input asp-for="Phone" class="form-control" placeholder="+91 98xxx xxxxx" />
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email</label>
                            <input asp-for="Email" class="form-control" placeholder="email@example.com" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Lead Source <span class="text-danger">*</span></label>
                            <select asp-for="LeadSource" class="form-select">
                                <option value="">-- Select --</option>
                                @foreach (var src in new[]{"99acres","MagicBricks","Referral","Walk-in","Website","Housing.com","Other"})
                                { <option>@src</option> }
                            </select>
                            <span asp-validation-for="LeadSource" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="fw-semibold mb-3 text-muted" style="font-size:12px;text-transform:uppercase;letter-spacing:.05em;">Property Interest</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Property Type <span class="text-danger">*</span></label>
                            <select asp-for="PropertyType" class="form-select">
                                <option value="">-- Select --</option>
                                @foreach (var t in new[]{"1BHK","2BHK","3BHK","4BHK","5BHK","Villa","Plot","Commercial","Penthouse"})
                                { <option>@t</option> }
                            </select>
                            <span asp-validation-for="PropertyType" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Location Preference <span class="text-danger">*</span></label>
                            <input asp-for="LocationPreference" class="form-control" placeholder="e.g. Andheri West, Powai" />
                            <span asp-validation-for="LocationPreference" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Budget Min (₹)</label>
                            <input asp-for="BudgetMin" class="form-control" placeholder="e.g. 1800000" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Budget Max (₹)</label>
                            <input asp-for="BudgetMax" class="form-control" placeholder="e.g. 2200000" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="fw-semibold mb-3 text-muted" style="font-size:12px;text-transform:uppercase;letter-spacing:.05em;">Notes</h6>
                    <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Any additional context about this lead..."></textarea>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="fw-semibold mb-3 text-muted" style="font-size:12px;text-transform:uppercase;letter-spacing:.05em;">Assignment & Timeframe</h6>
                    <div class="mb-3">
                        <label class="form-label">Assigned Agent</label>
                        <select asp-for="AgentId" class="form-select">
                            <option value="">-- Select Agent --</option>
                            @foreach (var a in Model.Agents)
                            { <option value="@a.Id">@a.FullName</option> }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Follow-up Deadline <span class="text-danger">*</span></label>
                        <input asp-for="FollowUpDeadline" type="date" class="form-control" />
                        <span asp-validation-for="FollowUpDeadline" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Close By Date <span class="text-danger">*</span></label>
                        <input asp-for="CloseByDate" type="date" class="form-control" />
                        <span asp-validation-for="CloseByDate" class="text-danger small"></span>
                        <small class="text-muted">Target date to convert this lead</small>
                    </div>
                </div>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Save Lead
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
