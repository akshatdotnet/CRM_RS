@model LeadListViewModel
@{ ViewData["Title"] = "All Leads"; ViewData["Breadcrumb"] = "All Leads"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-semibold">All Leads</h4>
    <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>New Lead</a>
</div>

<!-- Filters -->
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
        <div class="d-flex flex-wrap gap-2 align-items-center">
            <input type="text" id="leadSearch" class="form-control form-control-sm" style="max-width:220px;"
                   placeholder="Search name, phone, location..." value="@Model.SearchQuery" />
            @foreach (var stage in new[]{"New","Contacted","Site Visit","Negotiation","Closed","Lost"})
            {
                <a asp-action="Index" asp-route-stage="@stage"
                   class="btn btn-sm @(Model.StageFilter==stage?"btn-primary":"btn-outline-secondary")">@stage</a>
            }
            @if (!string.IsNullOrEmpty(Model.StageFilter) || !string.IsNullOrEmpty(Model.SearchQuery))
            {
                <a asp-action="Index" class="btn btn-sm btn-outline-danger">Clear</a>
            }
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name & Contact</th>
                        <th>Property Interest</th>
                        <th>Budget</th>
                        <th>Source</th>
                        <th>Stage</th>
                        <th>Follow-up</th>
                        <th>Agent</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var l in Model.Leads)
                    {
                        var dl = l.IsOverdue ? "overdue" : l.FollowUpDeadline <= DateTime.Today.AddDays(3) ? "warn" : "ok";
                        <tr>
                            <td>
                                <div class="fw-medium">@l.FullName</div>
                                <small class="text-muted">@l.Phone</small>
                            </td>
                            <td><small>@l.PropertyType · @l.LocationPreference</small></td>
                            <td><small>₹@((l.BudgetMin/100000).ToString("N0"))L – ₹@((l.BudgetMax/100000).ToString("N0"))L</small></td>
                            <td><small class="text-muted">@l.LeadSource</small></td>
                            <td><span class="badge-stage badge-@l.Stage.Replace(" ","-")">@l.Stage</span></td>
                            <td><span class="deadline-@dl">@l.FollowUpDeadline.ToString("MMM dd")</span></td>
                            <td><small>@l.AgentName</small></td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a asp-action="Details" asp-route-id="@l.Id" class="btn btn-sm btn-outline-primary" title="View"><i class="bi bi-eye"></i></a>
                                    <a asp-action="Edit" asp-route-id="@l.Id" class="btn btn-sm btn-outline-secondary" title="Edit"><i class="bi bi-pencil"></i></a>
                                    <form asp-action="Delete" asp-route-id="@l.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete"
                                                data-confirm="Delete this lead?" onclick="return confirm('Delete this lead?')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Leads.Any())
                    {
                        <tr><td colspan="8" class="text-center text-muted py-4">No leads found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
