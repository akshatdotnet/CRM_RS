@model AnalyticsViewModel
@{ ViewData["Title"] = "Analytics"; ViewData["Breadcrumb"] = "Analytics"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-semibold">Analytics</h4>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-2">
        <div class="metric-card">
            <div class="metric-label">Total Leads</div>
            <div class="metric-value text-primary">@Model.TotalLeads</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="metric-card">
            <div class="metric-label">Closed</div>
            <div class="metric-value text-success">@Model.ClosedDeals</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="metric-card">
            <div class="metric-label">Lost</div>
            <div class="metric-value text-danger">@Model.LostLeads</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="metric-card">
            <div class="metric-label">Total Revenue</div>
            <div class="metric-value" style="font-size:18px;color:#185FA5;">₹@((Model.TotalRevenue/10000000).ToString("N2")) Cr</div>
        </div>
    </div>
    <div class="col-md-1">
        <div class="metric-card">
            <div class="metric-label">Conv. %</div>
            <div class="metric-value" style="font-size:18px;color:#854F0B;">@Model.ConversionRate%</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="metric-card">
            <div class="metric-label">Avg Days to Close</div>
            <div class="metric-value" style="font-size:18px;color:#534AB7;">@Model.AvgDaysToClose</div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h6 class="fw-semibold mb-3">Stage Distribution</h6>
                @foreach (var s in Model.StageSummary)
                {
                    var pct = Model.TotalLeads > 0 ? (int)((double)s.Value / Model.TotalLeads * 100) : 0;
                    var color = s.Key switch { "New" => "#185FA5", "Contacted" => "#BA7517", "Site Visit" => "#534AB7", "Negotiation" => "#639922", "Closed" => "#0F6E56", _ => "#A32D2D" };
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span style="font-size:13px;">@s.Key</span>
                            <span style="font-size:13px;font-weight:500;">@s.Value <span class="text-muted fw-normal">(@pct%)</span></span>
                        </div>
                        <div class="progress" style="height:8px;border-radius:20px;">
                            <div class="progress-bar" style="width:@pct%;background:@color;border-radius:20px;"></div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h6 class="fw-semibold mb-3">Stage Conversion Funnel</h6>
                @foreach (var c in Model.StageConversion)
                {
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span style="font-size:13px;">@c.Key</span>
                            <span style="font-size:13px;font-weight:500;color:@(c.Value>=70?"#0F6E56":c.Value>=50?"#BA7517":"#A32D2D");">@c.Value%</span>
                        </div>
                        <div class="progress" style="height:8px;border-radius:20px;">
                            <div class="progress-bar" style="width:@c.Value%;background:@(c.Value>=70?"#0F6E56":c.Value>=50?"#BA7517":"#A32D2D");border-radius:20px;"></div>
                        </div>
                    </div>
                }
                <div class="mt-3 p-3 rounded" style="background:#f8f9fa;font-size:12px;">
                    <div class="fw-semibold mb-1">Insight</div>
                    <div class="text-muted">
                        @if (Model.StageConversion.Any(x => x.Value < 50))
                        {
                            var weak = Model.StageConversion.OrderBy(x => x.Value).First();
                            <span>Weakest stage: <strong>@weak.Key</strong> at @weak.Value%. Focus follow-up efforts here.</span>
                        }
                        else
                        {
                            <span>All conversion stages are above 50%. Good pipeline health!</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
