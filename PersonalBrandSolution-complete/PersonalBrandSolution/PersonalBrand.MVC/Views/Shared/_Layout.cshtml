<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@(ViewBag.Title ?? "Arjun Sharma · .NET & Azure Expert")</title>
  <meta name="description" content="@(ViewBag.Description ?? "Senior .NET Core Developer & Azure Cloud Architect with 15+ years experience.")" />
  <meta name="keywords" content=".NET Core, Azure, ASP.NET, Microservices, C#, DevOps, IT Consultant" />
  <meta property="og:title" content="@(ViewBag.Title ?? "Arjun Sharma · .NET & Azure Expert")" />
  <meta property="og:description" content="@(ViewBag.Description ?? "15+ years building scalable .NET & Azure cloud solutions.")" />
  <meta property="og:type" content="website" />
  <link rel="canonical" href="https://arjunsharma.dev" />

  <!-- Bootstrap 5 -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;700&family=Sora:wght@300;400;600;700;800&display=swap" rel="stylesheet" />
  <!-- Custom CSS -->
  <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

  <script type="application/ld+json">
  {
    "@@context": "https://schema.org",
    "@@type": "Person",
    "name": "@(ViewBag.PersonaName ?? "Arjun Sharma")",
    "jobTitle": "Senior .NET Core Developer & Azure Cloud Architect",
    "url": "https://arjunsharma.dev"
  }
  </script>
</head>
<body>

<!-- ═══ NAVBAR ═══ -->
<nav class="navbar navbar-expand-lg" id="mainNav" aria-label="Main navigation">
  <div class="container">
    <a class="nav-brand" href="#hero">&lt;<span>Arjun</span>Sharma /&gt;</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navMenu">
      <ul class="navbar-nav ms-auto align-items-center gap-1">
        <li class="nav-item"><a class="nav-link" href="#about">About</a></li>
        <li class="nav-item"><a class="nav-link" href="#roadmap">Roadmap</a></li>
        <li class="nav-item"><a class="nav-link" href="#courses">Courses</a></li>
        <li class="nav-item"><a class="nav-link" href="#projects">Projects</a></li>
        <li class="nav-item"><a class="nav-link" href="#qa">Q&amp;A</a></li>
        <li class="nav-item"><a class="nav-link" href="#consulting">Consulting</a></li>
        <li class="nav-item"><a class="nav-link" href="#pipeline">Pipeline</a></li>
        <li class="nav-item"><a class="nav-link" href="#blog">Blog</a></li>
        <li class="nav-item ms-2">
          <a class="btn-primary-custom" href="#contact" style="padding:9px 22px;font-size:0.75rem">
            <span><i class="bi bi-calendar-check me-1"></i>Hire Me</span>
          </a>
        </li>
      </ul>
    </div>
  </div>
</nav>

<!-- ═══ TOAST ═══ -->
@if (TempData["ToastMsg"] != null)
{
  <div id="serverToast"
       data-msg="@TempData["ToastMsg"]"
       data-type="@(TempData["ToastType"] ?? "success")"
       style="display:none"></div>
}

@RenderBody()

<!-- ═══ COOKIE BANNER ═══ -->
<div id="cookieBanner" role="alert" style="display:none">
  <i class="bi bi-cookie" style="color:var(--accent-cyan);font-size:1.3rem;flex-shrink:0"></i>
  <p>This site uses cookies to improve your experience. <a href="#" style="color:var(--accent-cyan)">Privacy Policy</a>.</p>
  <div style="display:flex;gap:8px;flex-shrink:0">
    <button class="btn-outline-custom" id="declineCookies" style="padding:8px 16px;font-size:0.72rem">Decline</button>
    <button class="btn-primary-custom" id="acceptCookies" style="padding:8px 16px;font-size:0.72rem"><span>Accept</span></button>
  </div>
</div>

<!-- Back to top -->
<a href="#hero" id="backToTop" aria-label="Back to top"
   style="position:fixed;bottom:80px;right:28px;z-index:999;width:42px;height:42px;background:linear-gradient(135deg,var(--accent-blue),var(--accent-cyan));border-radius:8px;display:flex;align-items:center;justify-content:center;color:#fff;text-decoration:none;font-size:1rem;opacity:0;transition:0.3s;pointer-events:none;box-shadow:0 4px 20px rgba(0,212,255,0.3)">
  <i class="bi bi-arrow-up"></i>
</a>

<!-- Lead Detail Modal -->
<div class="modal fade" id="leadModal" tabindex="-1">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="leadModalLabel">Lead Details</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body" id="leadModalBody">Loading...</div>
      <div class="modal-footer">
        <button type="button" class="btn-outline-custom" data-bs-dismiss="modal" style="font-size:0.78rem;padding:9px 20px">Close</button>
        <button type="button" class="btn-primary-custom" id="saveLeadBtn" style="font-size:0.78rem;padding:9px 20px">
          <span><i class="bi bi-check-circle me-1"></i>Save Changes</span>
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Scripts -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
