@model HRMS.WebPortal.Models.Salary.GenerateSalarySlipViewModel
@{ ViewData["Title"] = "Generate Salary Slip"; ViewData["ActiveNav"] = "Salary"; ViewData["PageTitle"] = "Generate Salary Slip"; }

<div class="page-header">
  <div><h1>Generate Salary Slip</h1><p>For: <strong>@Model.EmployeeName</strong></p></div>
  <a href="/Salary/Index?employeeId=@Model.EmployeeId&employeeName=@Uri.EscapeDataString(Model.EmployeeName)" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back</a>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage)) {
  <div class="alert alert-error"><i class="bi bi-exclamation-triangle-fill"></i> @Model.ErrorMessage</div>
}

<div class="card">
  <div class="card-header"><span class="card-title"><i class="bi bi-receipt" style="color:var(--accent)"></i> Slip Details</span></div>
  <div class="card-body">
    <form asp-action="Generate" method="post">
      @Html.AntiForgeryToken()
      <input type="hidden" asp-for="EmployeeId"/>
      <input type="hidden" asp-for="EmployeeName"/>

      <div class="form-grid-3">
        <div class="form-group">
          <label asp-for="Month">Month *</label>
          <select asp-for="Month" class="form-control">
            @for (int m = 1; m <= 12; m++) {
              <option value="@m" @@(m == DateTime.Now.Month ? "selected" : "")>@(new DateTime(2000, m, 1).ToString("MMMM"))</option>
            }
          </select>
        </div>
        <div class="form-group">
          <label asp-for="Year">Year *</label>
          <select asp-for="Year" class="form-control">
            @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 3; y--) {
              <option value="@y" @@(y == DateTime.Now.Year ? "selected" : "")>@y</option>
            }
          </select>
        </div>
        <div class="form-group">
          <label asp-for="PaidDays">Paid Days (leave blank = full month)</label>
          <input asp-for="PaidDays" type="number" class="form-control" placeholder="Leave blank for full month"/>
        </div>
        <div class="form-group">
          <label asp-for="OtherAllowances">Other Allowances (₹)</label>
          <input asp-for="OtherAllowances" type="number" step="100" min="0" class="form-control" value="0"/>
        </div>
        <div class="form-group">
          <label asp-for="OtherDeductions">Other Deductions (₹)</label>
          <input asp-for="OtherDeductions" type="number" step="100" min="0" class="form-control" value="0"/>
        </div>
      </div>

      <div style="display:flex;gap:12px;margin-top:8px;">
        <button type="submit" class="btn btn-primary"><i class="bi bi-receipt"></i> Generate Salary Slip</button>
        <a href="/Salary/Index?employeeId=@Model.EmployeeId&employeeName=@Uri.EscapeDataString(Model.EmployeeName)" class="btn btn-secondary">Cancel</a>
      </div>
    </form>
  </div>
</div>
